{
  "name": "mkagents",
  "version": "0.2.0",
  "description": "One scan, every agent's instruction file. Generate AGENTS.md, CLAUDE.md, Cursor rules, Copilot, Gemini, and Windsurf instruction files from a single deterministic repository scan.",
  "keywords": [
    "mkagents",
    "ai-agents",
    "agents.md",
    "agents-md",
    "claude-md",
    "cli",
    "codegen",
    "cursor",
    "claude-code",
    "copilot",
    "gemini",
    "windsurf"
  ],
  "homepage": "https://github.com/BitmapAsset/mkagents#readme",
  "bugs": {
    "url": "https://github.com/BitmapAsset/mkagents/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BitmapAsset/mkagents.git"
  },
  "license": "MIT",
  "author": "Gravity (BitmapAsset)",
  "type": "module",
  "bin": {
    "mkagents": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "node --test test/*.test.js",
    "pretest": "npm run build",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
